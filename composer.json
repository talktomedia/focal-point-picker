{
  "name": "hirasso/focal-point-picker",
  "description": "Zero-dependency custom focal point picker for your WordPress images 🎯",
  "type": "wordpress-plugin",
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "Rasso Hilber",
      "email": "mail@rassohilber.com",
      "homepage": "https://rassohilber.com"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "Hirasso\\FocalPointPicker\\": "src/"
    }
  },
  "require": {
    "php": ">=8.2",
    "composer/installers": "^2.3"
  },
  "require-dev": {
    "laravel/pint": "^1.25",
    "phpstan/phpstan": "^2.1",
    "roots/wordpress": "^6.8",
    "symfony/var-dumper": "^7.1",
    "wp-cli/wp-cli": "^2.12"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "composer/installers": true,
      "phpstan/extension-installer": true,
      "roots/wordpress-core-installer": true
    }
  },
  "extra": {
    "wordpress-install-dir": "vendor/.wordpress"
  }
}
